{
  "name": "sql-cockpit-service-control",
  "version": "1.0.3",
  "private": true,
  "description": "SQL Cockpit Windows Service Control desktop companion",
  "main": "main.js",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "electron .",
    "dev:watch": "node ./build/dev-watch.js",
    "dist": "node ./build/run-electron-builder.js nsis",
    "dist:portable": "node ./build/run-electron-builder.js portable"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^35.1.5",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.sqlcockpit.servicecontrol",
    "productName": "SQL Cockpit Service Control",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "build/setup-scripts",
        "to": "setup/scripts",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../DesktopBundle",
        "to": "setup/desktop",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../../icons",
        "to": "icons",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../Install-SqlCockpitWindowsService.ps1",
        "to": "setup/windows/Install-SqlCockpitWindowsService.ps1"
      },
      {
        "from": "../Uninstall-SqlCockpitWindowsService.ps1",
        "to": "setup/windows/Uninstall-SqlCockpitWindowsService.ps1"
      },
      {
        "from": "../Install-SqlCockpitServiceTrayStartup.ps1",
        "to": "setup/windows/Install-SqlCockpitServiceTrayStartup.ps1"
      },
      {
        "from": "../Uninstall-SqlCockpitServiceTrayStartup.ps1",
        "to": "setup/windows/Uninstall-SqlCockpitServiceTrayStartup.ps1"
      },
      {
        "from": "../Publish-SqlCockpitServiceControlElectron.ps1",
        "to": "setup/windows/Publish-SqlCockpitServiceControlElectron.ps1"
      },
      {
        "from": "../Prepare-SqlCockpitSuiteDesktopBundle.ps1",
        "to": "setup/windows/Prepare-SqlCockpitSuiteDesktopBundle.ps1"
      },
      {
        "from": "../Install-SqlCockpitSuite.ps1",
        "to": "setup/windows/Install-SqlCockpitSuite.ps1"
      },
      {
        "from": "../Repair-SqlCockpitSuite.ps1",
        "to": "setup/windows/Repair-SqlCockpitSuite.ps1"
      },
      {
        "from": "../sql-cockpit-service.settings.json",
        "to": "setup/windows/sql-cockpit-service.settings.json"
      },
      {
        "from": "../sql-cockpit-service.dev.settings.json",
        "to": "setup/windows/sql-cockpit-service.dev.settings.json"
      },
      {
        "from": "../sql-cockpit-service.prod.settings.json",
        "to": "setup/windows/sql-cockpit-service.prod.settings.json"
      },
      {
        "from": "../SqlCockpit.ServiceHost.Windows",
        "to": "setup/windows/SqlCockpit.ServiceHost.Windows",
        "filter": [
          "**/*",
          "!**/bin/**",
          "!**/obj/**"
        ]
      }
    ],
    "directories": {
      "output": "../publish/electron-control"
    },
    "win": {
      "icon": "../../icons/windows/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "icon": "../../icons/macos/icon.icns"
    },
    "linux": {
      "icon": "../../icons/linux/icons"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "perMachine": true,
      "include": "build/installer.nsh"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "jjmpsp",
        "repo": "sql-cockpit-servicemanager",
        "releaseType": "release"
      }
    ]
  }
}
