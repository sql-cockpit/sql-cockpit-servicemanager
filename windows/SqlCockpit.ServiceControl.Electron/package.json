{
  "name": "sql-cockpit-service-control",
  "version": "1.0.0",
  "private": true,
  "description": "SQL Cockpit Windows Service Control desktop companion",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "dist": "electron-builder --win nsis",
    "dist:portable": "electron-builder --win portable"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^35.1.5",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.sqlcockpit.servicecontrol",
    "productName": "SQL Cockpit Service Control",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "directories": {
      "output": "../publish/electron-control"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "jjmpsp",
        "repo": "SQL-Tables-Sync",
        "releaseType": "release"
      }
    ]
  }
}
