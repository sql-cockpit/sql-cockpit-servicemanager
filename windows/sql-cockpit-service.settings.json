{
  "serviceName": "SQLCockpitServiceHost",
  "repoRoot": "C:\\Scripts\\SQL Tables Sync",
  "desktopRepoRoot": "C:\\Scripts\\SQL Tables Sync\\webapp",
  "apiRepoRoot": "C:\\Scripts\\SQL Tables Sync\\sql-cockpit-api",
  "serviceRepoRoot": "C:\\Scripts\\SQL Tables Sync\\service",
  "objectSearchRepoRoot": "C:\\Scripts\\SQL Tables Sync\\object-search",
  "listenPrefix": "http://127.0.0.1:8610/",
  "requireLocalRequests": true,
  "apiKey": "",
  "installationMode": "suite",
  "autoStart": true,
  "autoRestart": true,
  "healthPollSeconds": 5,
  "healthFailureThreshold": 3,
  "restartDelaySeconds": 3,
  "components": [
    {
      "id": "web-api",
      "displayName": "SQL Cockpit Web API",
      "disabled": false,
      "autoStart": true,
      "command": "node",
      "workingDirectory": "{ApiRepoRoot}",
      "args": [
        "server.js",
        "--configServer",
        "NASCAR",
        "--configDatabase",
        "EPC_Imports_PCK",
        "--configSchema",
        "Sync",
        "--configIntegratedSecurity",
        "--trustServerCertificate",
        "--listenPrefix",
        "http://127.0.0.1:8000/",
        "--notificationsListenPrefix",
        "http://127.0.0.1:8090/",
        "--runtimeProfile",
        "prod",
        "--serviceHostControlUrl",
        "http://127.0.0.1:8610/",
        "--manageComponents",
        "false"
      ],
      "healthUrl": "http://127.0.0.1:8000/health"
    },
    {
      "id": "docs",
      "displayName": "Docs server",
      "disabled": false,
      "autoStart": true,
      "command": "powershell.exe",
      "workingDirectory": "{RepoRoot}",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "{RepoRoot}\\Start-SqlTablesSyncDocsServer.ps1",
        "-ListenPrefix",
        "http://127.0.0.1:8001/",
        "-ForceStaticServer"
      ],
      "healthUrl": "http://127.0.0.1:8001/"
    },
    {
      "id": "notifications",
      "displayName": "Notifications server",
      "disabled": false,
      "autoStart": true,
      "command": "powershell.exe",
      "workingDirectory": "{RepoRoot}",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "{RepoRoot}\\Start-SqlTablesSyncNotificationsServer.ps1",
        "-ListenPrefix",
        "http://127.0.0.1:8090/"
      ],
      "healthUrl": "http://127.0.0.1:8090/health"
    },
    {
      "id": "object-search",
      "displayName": "Object search service",
      "disabled": false,
      "autoStart": true,
      "command": "powershell.exe",
      "workingDirectory": "{ObjectSearchRepoRoot}",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "{ObjectSearchRepoRoot}\\Start-SqlObjectSearchService.ps1",
        "-SettingsPath",
        "{ObjectSearchRepoRoot}\\sql-object-search.settings.json"
      ],
      "healthUrl": "http://127.0.0.1:8094/health"
    },
    {
      "id": "desktop-app",
      "displayName": "SQL Cockpit Electron desktop app",
      "disabled": false,
      "autoStart": false,
      "autoRestart": false,
      "command": "powershell.exe",
      "workingDirectory": "{ServiceRepoRoot}",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "{RepoRoot}\\Start-SqlCockpitDesktopPackaged.ps1",
        "-ConfigServer",
        "NASCAR",
        "-ConfigDatabase",
        "EPC_Imports_PCK",
        "-ConfigSchema",
        "Sync",
        "-ConfigIntegratedSecurity",
        "-TrustServerCertificate",
        "-ListenPrefix",
        "http://127.0.0.1:8000/",
        "-NotificationsListenPrefix",
        "http://127.0.0.1:8090/",
        "-DocsListenPrefix",
        "http://127.0.0.1:8001/",
        "-RuntimeProfile",
        "prod",
        "-ManageComponents",
        "false",
        "-ExternalApiOnly",
        "true",
        "-DesktopExecutablePath",
        "C:\\Program Files\\SQL Cockpit\\SQL Cockpit.exe",
        "-ServiceHostControlUrl",
        "http://127.0.0.1:8610/"
      ],
      "healthUrl": ""
    }
  ]
}
